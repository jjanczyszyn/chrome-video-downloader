{
  "name": "course-library-exporter",
  "version": "1.0.0",
  "description": "Chrome extension to crawl and export course structure with downloadable resources",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "mock:server": "tsx mock-site/server.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.23.1",
    "express": "^4.21.0",
    "@types/express": "^4.17.21",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  }
}
